{
  "name": "livon-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run build:watch dev gen:client:watch --filter=./packages/* --filter=./apps/*",
    "docs": "turbo run docs --filter=./website",
    "docs:sync:package-readmes": "node tools/docs/sync-package-readmes.mjs",
    "docs:check:package-readmes": "node tools/docs/sync-package-readmes.mjs --check",
    "test": "vitest run --passWithNoTests",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "gen": "node tools/gen/index.mjs",
    "check:policies": "node tools/policies/check.mjs",
    "changeset": "pnpm dlx @changesets/cli",
    "changeset:version": "pnpm dlx @changesets/cli version",
    "changeset:publish": "pnpm dlx @changesets/cli publish"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "version": "0.27.0-rc.3"
}
