{
  "name": "livon-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo run build:watch",
    "ci": "turbo run ci --output-logs=errors-only",
    "qg": "turbo run qg --output-logs=errors-only",
    "qg:changed": "turbo run qg --affected --output-logs=errors-only",
    "dev": "turbo run build:watch dev gen:client:watch",
    "docs": "turbo run docs",
    "bench": "turbo run bench --output-logs=errors-only",
    "bench:gate": "turbo run bench:gate --output-logs=errors-only",
    "bench:matrix:adaptive": "turbo run bench:matrix:adaptive --output-logs=errors-only",
    "bench:matrix:lru-set": "turbo run bench:matrix:lru-set --output-logs=errors-only",
    "bench:ui": "turbo run bench -- --ui",
    "test": "turbo run test --output-logs=errors-only",
    "lint": "turbo run lint --output-logs=errors-only",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck --output-logs=errors-only",
    "test:unit": "turbo run test:unit --output-logs=errors-only",
    "test:integration": "turbo run test:integration --output-logs=errors-only",
    "gen": "turbo run gen --",
    "gen:client": "turbo run gen:client --",
    "gen:client:deploy": "turbo run gen:client:deploy --",
    "gen:client:watch": "turbo run gen:client:watch",
    "gen:readmes": "turbo run gen:readmes",
    "check:readmes": "turbo run check:readmes --output-logs=errors-only",
    "check:links": "turbo run check:links --output-logs=errors-only",
    "release:check": "turbo run release:check --output-logs=errors-only",
    "check:policies": "turbo run check:policies --output-logs=errors-only",
    "metrics:ai-control": "turbo run metrics:ai-control",
    "changeset": "turbo run changeset",
    "changeset:version": "turbo run changeset:version",
    "changeset:sync-root-version": "turbo run changeset:sync-root-version",
    "changeset:publish": "turbo run changeset:publish"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "version": "0.29.0-rc.4"
}
