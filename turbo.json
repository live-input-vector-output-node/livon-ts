{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "100",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "@livon/config#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/gen#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/policies#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/readmes#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/release#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "build:watch": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "gen:client:watch": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "outputs": [
        "src/generated/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "ci": {
      "dependsOn": [
        "qg"
      ],
      "outputs": []
    },
    "qg": {
      "dependsOn": [
        "check:readmes",
        "check:policies",
        "lint",
        "typecheck",
        "test",
        "build"
      ],
      "outputs": []
    },
    "gen:readmes": {
      "outputs": []
    },
    "check:readmes": {
      "outputs": []
    },
    "check:policies": {
      "outputs": []
    },
    "check:links": {
      "outputs": []
    },
    "metrics:ai-control": {
      "outputs": []
    },
    "gen": {
      "outputs": []
    },
    "gen:client": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "gen:client:deploy": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "bench": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "release:check": {
      "outputs": []
    },
    "changeset": {
      "cache": false,
      "outputs": []
    },
    "changeset:version": {
      "cache": false,
      "outputs": []
    },
    "changeset:sync-root-version": {
      "cache": false,
      "outputs": []
    },
    "changeset:publish": {
      "cache": false,
      "outputs": []
    }
  }
}
