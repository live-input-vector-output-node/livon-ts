{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "build:watch": {
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**", "build/**"]
    },
    "gen:client:watch": {
      "cache": false,
      "persistent": true,
      "outputs": ["src/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    }
  }
}
