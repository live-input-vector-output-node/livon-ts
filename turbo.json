{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "100",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "turbo.json",
    "configs/**"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "@livon/typescript#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/eslint#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/rslib#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/rsbuild#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/rspack#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/vitest#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/swc#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/gen#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/policies#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/readmes#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "@livon/release#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "build:watch": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "gen:client:watch": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true,
      "outputs": [
        "src/generated/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "ci": {
      "dependsOn": [
        "qg"
      ],
      "outputs": []
    },
    "qg": {
      "dependsOn": [
        "qg:parallel"
      ],
      "outputs": []
    },
    "qg:parallel": {
      "dependsOn": [
        "qg:bench"
      ],
      "with": [
        "check:readmes",
        "check:badges",
        "check:policies",
        "lint",
        "typecheck",
        "test",
        "build"
      ],
      "outputs": []
    },
    "qg:bench": {
      "dependsOn": [
        "bench:gate"
      ],
      "outputs": []
    },
    "gen:readmes": {
      "outputs": []
    },
    "@livon/readmes#gen:readmes": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../configs/docs/readme-sync.json",
        "../../website/docs/**",
        "../../packages/*/README.md",
        "../../CONTRIBUTING.md",
        "../../GOVERNANCE.md",
        "../../CODE_OF_CONDUCT.md",
        "../../SUPPORT.md",
        "../../SECURITY.md",
        "../../CHANGELOG.md",
        "../../.github/SECURITY.md"
      ],
      "outputs": []
    },
    "check:readmes": {
      "outputs": []
    },
    "@livon/readmes#check:readmes": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../configs/docs/readme-sync.json",
        "../../website/docs/**",
        "../../packages/*/README.md",
        "../../CONTRIBUTING.md",
        "../../GOVERNANCE.md",
        "../../CODE_OF_CONDUCT.md",
        "../../SUPPORT.md",
        "../../SECURITY.md",
        "../../CHANGELOG.md",
        "../../.github/SECURITY.md"
      ],
      "outputs": []
    },
    "check:badges": {
      "dependsOn": [
        "check:readmes"
      ],
      "outputs": []
    },
    "check:policies": {
      "cache": false,
      "outputs": []
    },
    "check:links": {
      "cache": false,
      "outputs": []
    },
    "metrics:ai-control": {
      "cache": false,
      "outputs": []
    },
    "gen": {
      "outputs": []
    },
    "gen:client": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "gen:client:deploy": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "bench": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "bench:gate": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "bench:execution-mode": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "bench:matrix:lru-set": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "bench:matrix:adaptive": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": []
    },
    "release:check": {
      "outputs": []
    },
    "changeset": {
      "cache": false,
      "outputs": []
    },
    "changeset:version": {
      "cache": false,
      "outputs": []
    },
    "changeset:sync-root-version": {
      "cache": false,
      "outputs": []
    },
    "changeset:publish": {
      "cache": false,
      "outputs": []
    }
  }
}
