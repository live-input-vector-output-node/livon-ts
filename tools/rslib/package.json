{
  "name": "@livon/rslib",
  "version": "0.29.0-rc.11",
  "private": true,
  "type": "module",
  "description": "Composable Rslib presets for LIVON workspaces.",
  "exports": {
    ".": "./src/index.ts",
    "./base": "./src/base.ts",
    "./browser": "./src/browser.ts",
    "./node": "./src/node.ts",
    "./react": "./src/react.ts",
    "./entry": "./src/entry.ts",
    "./library": "./src/library.ts",
    "./compose": "./src/compose.ts"
  },
  "peerDependencies": {
    "@rslib/core": "^0.19.5 || ^0.20.0"
