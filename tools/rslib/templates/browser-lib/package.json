{
  "name": "@livon/browser-lib",
  "version": "0.29.0-rc.11",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts",
    "test:unit": "vitest run --configLoader runner -c vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts"
  },
  "devDependencies": {
    "@livon/vitest": "workspace:*",
    "@livon/eslint": "workspace:*",
    "@livon/rslib": "workspace:*",
    "@livon/typescript": "workspace:*",
    "@rslib/core": "latest",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "eslint": "10.2.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
