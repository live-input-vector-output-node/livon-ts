{
  "name": "@livon/eslint",
  "version": "0.29.0-rc.11",
  "private": true,
  "type": "module",
  "description": "Composable ESLint flat-config presets for LIVON workspaces.",
  "exports": {
    ".": "./src/index.ts",
    "./base": "./src/base.ts",
    "./browser": "./src/browser.ts",
    "./node": "./src/node.ts",
    "./react": "./src/react.ts",
    "./compose": "./src/compose.ts"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2"
  },
  "scripts": {
    "build": "true",
    "build:watch": "true",
    "dev": "true",
    "lint": "true",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "devDependencies": {
    "@livon/typescript": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
