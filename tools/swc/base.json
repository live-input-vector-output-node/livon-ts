{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": false
    },
    "target": "es2021",
    "minify": {
      "compress": false,
      "mangle": false
    }
  },
  "module": {
    "type": "nodenext"
  },
  "sourceMaps": true
}
