{
  "name": "@livon/frontend-app",
  "version": "0.29.0-rc.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "preview": "rsbuild preview",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts",
    "test:unit": "vitest run --configLoader runner -c vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@rsbuild/core": "latest",
    "@rsbuild/plugin-react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "vitest": "latest",
    "@livon/config": "workspace:*"
  }
}
