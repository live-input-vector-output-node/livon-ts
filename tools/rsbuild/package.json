{
  "name": "@livon/rsbuild",
  "version": "0.29.0-rc.11",
  "private": true,
  "type": "module",
  "description": "Composable Rsbuild presets for LIVON workspaces.",
  "exports": {
    ".": "./src/index.ts",
    "./base": "./src/base.ts",
    "./browser": "./src/browser.ts",
    "./node": "./src/node.ts",
    "./react": "./src/react.ts",
    "./entry": "./src/entry.ts",
    "./html": "./src/html.ts",
    "./compose": "./src/compose.ts"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.5"
  },
  "scripts": {
    "build": "true",
    "build:watch": "true",
    "dev": "true",
    "lint": "true",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "devDependencies": {
    "@livon/typescript": "workspace:*",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
