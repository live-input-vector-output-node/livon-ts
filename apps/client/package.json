{
  "name": "@livon/app-client",
  "version": "0.28.0-rc.4",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "keywords": [
    "livon",
    "app",
    "client",
    "react",
    "typescript"
  ],
  "scripts": {
    "build": "rsbuild build",
    "build:watch": "true",
    "dev": "PORT=3001 rsbuild dev",
    "gen:client:watch": "livon --endpoint ws://127.0.0.1:3002/ws --out src/generated/api.ts --poll 2000",
    "gen:client:deploy": "livon --endpoint ws://127.0.0.1:3002/ws --out src/generated/api.ts --emit-package-json",
    "preview": "rsbuild preview",
    "lint": "eslint . --max-warnings 3",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts",
    "test:unit": "vitest run --configLoader runner -c vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts",
    "gen:client": "livon --endpoint ws://127.0.0.1:3002/ws --out src/generated/api.ts"
  },
  "dependencies": {
    "@livon/client": "workspace:*",
    "@livon/client-ws-transport": "workspace:*",
    "@livon/runtime": "workspace:*",
    "react": "latest",
    "react-dom": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@livon/cli": "workspace:*",
    "@livon/config": "workspace:*",
    "@rsbuild/core": "latest",
    "@rsbuild/plugin-react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "vitest": "latest"
  }
}
