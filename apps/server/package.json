{
  "name": "@livon/app-server",
  "version": "0.29.0-rc.7",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "keywords": [
    "livon",
    "app",
    "server",
    "node",
    "typescript"
  ],
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "HOST=0.0.0.0 LIVON_PORT=3002 LIVON_EXPLAIN=1 node --watch-path=dist --watch-preserve-output dist/index.js",
    "preview": "HOST=0.0.0.0 LIVON_PORT=3002 node dist/index.js",
    "lint": "eslint . --max-warnings 5",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts",
    "test:unit": "vitest run --configLoader runner -c vitest.unit.config.ts",
    "test:integration": "vitest run --passWithNoTests --configLoader runner -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@livon/dlq-module": "workspace:*",
    "@livon/runtime": "workspace:*",
    "@livon/schema": "workspace:*",
    "@livon/node-ws-transport": "workspace:*",
    "msgpackr": "latest",
    "ws": "latest"
  },
  "devDependencies": {
    "@livon/config": "workspace:*",
    "@rslib/core": "latest",
    "@types/node": "latest",
    "@types/ws": "latest",
    "eslint": "10.0.2",
    "superwstest": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
