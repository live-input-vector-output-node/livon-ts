{
  "name": "@livon/client-ws-transport",
  "version": "0.27.0-rc.4",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENCE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mini": {
      "types": "./dist/mini/index.d.ts",
      "import": "./dist/mini/index.js",
      "require": "./dist/mini/index.cjs"
    }
  },
  "scripts": {
    "build": "node ../../tools/build/rslib-dual-build.mjs",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@livon/client": "workspace:*",
    "@livon/runtime": "workspace:*",
    "msgpackr": "latest"
  },
  "devDependencies": {
    "@livon/config": "workspace:*",
    "@rslib/core": "latest",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "eslint": "9.0.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
