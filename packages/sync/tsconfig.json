{
  "extends": [
    "@livon/typescript/base",
    "@livon/typescript/library",
    "@livon/typescript/browser"
  ],
  "include": [
    "src",
    "*.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.spec.*",
    "src/**/*.test.*",
    "src/**/*.bench.*",
    "src/**/*.benchmark.*",
    "src/**/__mocks__/**",
    "src/**/mocks/**",
    "src/**/testing/**",
    "src/**/tests/**"
  ]
}
