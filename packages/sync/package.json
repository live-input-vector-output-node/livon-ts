{
  "name": "@livon/sync",
  "version": "0.28.0-rc.1",
  "private": false,
  "type": "module",
  "description": "Entity-centric sync layer for LIVON sources, actions, and streams.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/sync"
  },
  "homepage": "https://livon.tech/docs/packages/sync",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "sync",
    "state",
    "realtime",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "true"
  },
  "dependencies": {},
  "devDependencies": {
    "@rslib/core": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "vitest": "latest",
    "@livon/config": "workspace:*"
  }
}
