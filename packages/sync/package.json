{
  "name": "@livon/sync",
  "version": "0.29.0-rc.2",
  "private": false,
  "type": "module",
  "description": "Entity-centric sync layer for LIVON sources, actions, and streams.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/sync"
  },
  "homepage": "https://livon.tech/docs/packages/sync",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "sync",
    "realtime",
    "state",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./action": {
      "types": "./dist/action.d.ts",
      "development": "./src/action.ts",
      "import": "./dist/action.js",
      "require": "./dist/action.cjs"
    },
    "./entity": {
      "types": "./dist/entity.d.ts",
      "development": "./src/entity.ts",
      "import": "./dist/entity.js",
      "require": "./dist/entity.cjs"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "development": "./src/source.ts",
      "import": "./dist/source.js",
      "require": "./dist/source.cjs"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "development": "./src/stream.ts",
      "import": "./dist/stream.js",
      "require": "./dist/stream.cjs"
    },
    "./view": {
      "types": "./dist/view.d.ts",
      "development": "./src/view.ts",
      "import": "./dist/view.js",
      "require": "./dist/view.cjs"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "development": "./src/transform.ts",
      "import": "./dist/transform.js",
      "require": "./dist/transform.cjs"
    },
    "./tracking": {
      "types": "./dist/tracking/index.d.ts",
      "development": "./src/tracking/index.ts",
      "import": "./dist/tracking/index.js",
      "require": "./dist/tracking/index.cjs"
    }
  },
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "true",
    "bench": "vitest bench -c vitest.bench.config.ts",
    "bench:gate": "node ./scripts/run-bench-gate.mjs"
  },
  "dependencies": {
    "msgpackr": "1.11.8"
  },
  "devDependencies": {
    "@rslib/core": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "vitest": "latest",
    "@livon/config": "workspace:*"
  }
}
