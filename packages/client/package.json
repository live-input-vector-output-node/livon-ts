{
  "name": "@livon/client",
  "version": "0.27.0-rc.5",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mini": {
      "types": "./dist/mini/index.d.ts",
      "import": "./dist/mini/index.js",
      "require": "./dist/mini/index.cjs"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "import": "./dist/generate.js",
      "require": "./dist/generate.cjs"
    },
    "./generate/mini": {
      "types": "./dist/mini/generate.d.ts",
      "import": "./dist/mini/generate.js",
      "require": "./dist/mini/generate.cjs"
    }
  },
  "files": [
    "dist",
    "LICENCE.md"
  ],
  "scripts": {
    "build": "rslib build",
    "postbuild": "rslib build -c rslib.mini.config.ts",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 23",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "dependencies": {
    "@livon/config": "workspace:*",
    "@livon/runtime": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "latest",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "@livon/config": "workspace:*"
  }
}
