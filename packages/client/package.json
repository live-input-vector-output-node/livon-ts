{
  "name": "@livon/client",
  "version": "0.28.0-rc.4",
  "private": false,
  "type": "module",
  "description": "Client runtime and generated client foundations for LIVON.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "import": "./dist/generate.js",
      "require": "./dist/generate.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/client"
  },
  "homepage": "https://livon.tech/docs/packages/client",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "client",
    "api",
    "codegen",
    "typescript"
  ],
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 23",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "dependencies": {
    "@livon/runtime": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "latest",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "@livon/config": "workspace:*"
  }
}
