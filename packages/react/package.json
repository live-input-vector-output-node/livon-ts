{
  "name": "@livon/react",
  "version": "0.29.0-rc.2",
  "private": false,
  "type": "module",
  "description": "React adapter and hooks for LIVON sync units.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/react"
  },
  "homepage": "https://livon.tech/docs/packages/react",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "react",
    "hooks",
    "sync",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "development": "./src/types.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./useLivonActionState": {
      "types": "./dist/useLivonActionState.d.ts",
      "development": "./src/useLivonActionState.ts",
      "import": "./dist/useLivonActionState.js",
      "require": "./dist/useLivonActionState.cjs"
    },
    "./useLivonDraft": {
      "types": "./dist/useLivonDraft.d.ts",
      "development": "./src/useLivonDraft.ts",
      "import": "./dist/useLivonDraft.js",
      "require": "./dist/useLivonDraft.cjs"
    },
    "./useLivonMeta": {
      "types": "./dist/useLivonMeta.d.ts",
      "development": "./src/useLivonMeta.ts",
      "import": "./dist/useLivonMeta.js",
      "require": "./dist/useLivonMeta.cjs"
    },
    "./useLivonRun": {
      "types": "./dist/useLivonRun.d.ts",
      "development": "./src/useLivonRun.ts",
      "import": "./dist/useLivonRun.js",
      "require": "./dist/useLivonRun.cjs"
    },
    "./useLivonSourceState": {
      "types": "./dist/useLivonSourceState.d.ts",
      "development": "./src/useLivonSourceState.ts",
      "import": "./dist/useLivonSourceState.js",
      "require": "./dist/useLivonSourceState.cjs"
    },
    "./useLivonState": {
      "types": "./dist/useLivonState.d.ts",
      "development": "./src/useLivonState.ts",
      "import": "./dist/useLivonState.js",
      "require": "./dist/useLivonState.cjs"
    },
    "./useLivonStatus": {
      "types": "./dist/useLivonStatus.d.ts",
      "development": "./src/useLivonStatus.ts",
      "import": "./dist/useLivonStatus.js",
      "require": "./dist/useLivonStatus.cjs"
    },
    "./useLivonStop": {
      "types": "./dist/useLivonStop.d.ts",
      "development": "./src/useLivonStop.ts",
      "import": "./dist/useLivonStop.js",
      "require": "./dist/useLivonStop.cjs"
    },
    "./useLivonStreamState": {
      "types": "./dist/useLivonStreamState.d.ts",
      "development": "./src/useLivonStreamState.ts",
      "import": "./dist/useLivonStreamState.js",
      "require": "./dist/useLivonStreamState.cjs"
    },
    "./useLivonValue": {
      "types": "./dist/useLivonValue.d.ts",
      "development": "./src/useLivonValue.ts",
      "import": "./dist/useLivonValue.js",
      "require": "./dist/useLivonValue.cjs"
    }
  },
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "true"
  },
  "dependencies": {
    "@livon/sync": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@livon/config": "workspace:*",
    "@rslib/core": "latest",
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "jsdom": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
