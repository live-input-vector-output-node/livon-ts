{
  "name": "@livon/cli",
  "version": "0.27.0-rc.3",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mini": {
      "types": "./dist/mini/index.d.ts",
      "import": "./dist/mini/index.js",
      "require": "./dist/mini/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "LICENCE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "bin": {
    "livon": "bin/livon.js"
  },
  "scripts": {
    "build": "node ../../tools/build/rslib-dual-build.mjs",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "dependencies": {
    "@livon/client": "workspace:*",
    "@livon/config": "workspace:*",
    "msgpackr": "latest",
    "ws": "latest"
  },
  "devDependencies": {
    "@rslib/core": "latest",
    "@types/ws": "latest",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "@types/node": "latest",
    "eslint": "9.0.0",
    "typescript": "latest",
    "@livon/config": "workspace:*"
  }
}
