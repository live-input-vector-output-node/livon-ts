{
  "name": "@livon/cli",
  "version": "0.28.0-rc.4",
  "private": false,
  "type": "module",
  "description": "CLI for LIVON client sync and generated API workflows.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "author": "cr15p1 <62719241+cr15p1@users.noreply.github.com>",
  "contributors": [
    "cr15p1 <62719241+cr15p1@users.noreply.github.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/cli"
  },
  "homepage": "https://livon.tech/docs/packages/cli",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "cli",
    "sync",
    "codegen",
    "typescript"
  ],
  "bin": {
    "livon": "bin/livon.js"
  },
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 7",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "true",
    "test:unit": "true",
    "test:integration": "true"
  },
  "dependencies": {
    "@rslib/core": "0.19.5",
    "@livon/client": "workspace:*",
    "msgpackr": "1.11.8",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/ws": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@types/node": "latest",
    "eslint": "10.0.2",
    "typescript": "latest",
    "@livon/config": "workspace:*"
  }
}
