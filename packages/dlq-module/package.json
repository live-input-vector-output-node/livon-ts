{
  "name": "@livon/dlq-module",
  "version": "0.29.0-rc.5",
  "private": false,
  "type": "module",
  "description": "Dead-letter queue module for LIVON runtime pipelines.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
      "url": "https://github.com/cr15p1"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/live-input-vector-output-node/livon-ts.git",
    "directory": "packages/dlq-module"
  },
  "homepage": "https://livon.tech/docs/packages/dlq-module",
  "bugs": {
    "url": "https://github.com/live-input-vector-output-node/livon-ts/issues"
  },
  "keywords": [
    "livon",
    "runtime",
    "queue",
    "dlq",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "rslib build",
    "build:watch": "rslib dev",
    "dev": "true",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@livon/runtime": "workspace:*"
  },
  "devDependencies": {
    "@livon/config": "workspace:*",
    "@rslib/core": "latest",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "typescript": "latest",
    "vitest": "latest"
  }
}
