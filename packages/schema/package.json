{
  "name": "@livon/schema",
  "version": "0.29.0-rc.10",
  "private": false,
  "type": "module",
  "description": "Schema builders, validators, and API definitions for LIVON.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "license": "MIT",
  "author": {
    "name": "LIVON",
    "url": "https://livon.tech"
  },
  "contributors": [
    {
      "name": "cr15p1",
